# Local example values. On Vercel Preview and Production, replace these with your hosted Supabase project values.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_local_or_hosted_key

# Required for hosted public contact form submissions.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
CONTACT_IP_HASH_SECRET=replace_with_random_32_byte_secret
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_cloudflare_turnstile_site_key
TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_key

# Optional observability. Set in Vercel if Sentry or an equivalent provider is used.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Optional access filter. Use "off" by default; "admin" restricts dashboard/login APIs to Finland,
# "all" restricts the full web app to Finland. Prefer Cloudflare WAF for hard edge enforcement.
OMALEIMA_GEOFENCE_MODE=off
